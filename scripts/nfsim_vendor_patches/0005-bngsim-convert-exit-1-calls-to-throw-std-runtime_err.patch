 src/NFcore/system.cpp                  | 24 ++++++++++++------------
 src/NFfunction/compositeFunction.cpp   | 12 ++++++------
 src/NFfunction/function.cpp            | 10 +++++-----
 src/NFinput/NFinput.cpp                | 23 ++++++++++++-----------
 src/NFreactions/reactions/reaction.cpp | 16 ++++++++--------
 6 files changed, 54 insertions(+), 53 deletions(-)

