{
 "_meta": {
  "suite": "ode_engines_s4_sbml",
  "description": "Cross-engine ODE timing on the six largest curated SBML BioModels carrying a real figure-tied horizon (the SBML counterpart to Table S3). Cold = one-time build + first solve; warm = median of subsequent solves. SBML engines (RoadRunner/AMICI/COPASI) and BNGsim ingest the curated SBML natively; run_network integrates a .net derived offline via bngsim.sbml_to_net (model-prep, not charged; recorded in net_conversion).",
  "engines": [
   "run_network",
   "bngsim",
   "roadrunner",
   "amici_klu",
   "amici_dense",
   "copasi"
  ],
  "metric": {
   "cold": "build_sec + integrate_cold_sec (= cold_total_sec)",
   "warm": "integrate_warm_median_sec (= warm_sec)",
   "warm_reps": {
    "max": 5,
    "budget_sec": 3.0
   }
  },
  "horizon_source": "figure_sedml (rr_parity ode_jobs.json, per-model)",
  "horizon_note": "integration span = [SED-ML initialTime, outputEndTime] so pre-window events fire; output_start = SED-ML outputStartTime (plotted window).",
  "tol_override": {
   "rtol": null,
   "atol": null
  },
  "convert_gate": "L2",
  "versions": {
   "bngsim": "0.11.35",
   "roadrunner": "2.9.2",
   "amici": "1.0.1",
   "libsbml": "5.21.0",
   "copasi": "4.46.300 (Source)",
   "sundials": "7.2.1"
  },
  "hardware": {
   "cpu": "Apple M4 Max",
   "physical_cores": 16,
   "logical_cores": 16,
   "platform": "macOS-26.5.1-arm64-arm-64bit"
  },
  "n_results": 6
