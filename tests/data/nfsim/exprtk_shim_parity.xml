<?xml version="1.0" encoding="UTF-8"?>
<!-- Hand-authored fixture for the NFsim ExprTk-shim parity test (issue #49).
     Exercises the two BNG-compatibility carries that live ONLY in NFsim's
     mu::Parser shim (third_party/nfsim/src/NFfunction/nfsim_funcparser.h):
       * mratio()  built-in  -> the m_* functions below (constant arguments,
                                so their value is deterministic and engine-
                                independent: it depends only on the shim's
                                mratio implementation).
       * reserved-symbol remap -> the observable `frac` collides with an ExprTk
                                built-in; `reserved_frac() = frac + 10` only
                                compiles if the shim remaps `frac` -> `r_frac`.
     `frac` counts molecules of F; no rule touches F, so frac == 7 for all time.
     These function columns are computed by NFsim's shim (FuncFactory::Eval),
     not the host bngsim::ExprTkEvaluator (see nfsim_simulator.cpp). -->
<sbml xmlns="http://www.sbml.org/sbml/level3" level="3" version="1">
  <model id="exprtk_shim_parity">
    <ListOfParameters>
      <Parameter id="kcat" type="Constant" value="0.7" expr="0.7"/>
    </ListOfParameters>
    <ListOfMoleculeTypes>
      <MoleculeType id="X">
        <ListOfComponentTypes>
          <ComponentType id="p">
            <ListOfAllowedStates>
              <AllowedState id="0"/>
              <AllowedState id="1"/>
            </ListOfAllowedStates>
          </ComponentType>
        </ListOfComponentTypes>
      </MoleculeType>
      <MoleculeType id="F">
        <ListOfComponentTypes>
        </ListOfComponentTypes>
      </MoleculeType>
    </ListOfMoleculeTypes>
    <ListOfCompartments>
    </ListOfCompartments>
    <ListOfSpecies>
      <Species id="S1" concentration="100" name="X(p~0)">
        <ListOfMolecules>
          <Molecule id="S1_M1" name="X">
            <ListOfComponents>
              <Component id="S1_M1_C1" name="p" state="0" numberOfBonds="0"/>
            </ListOfComponents>
          </Molecule>
        </ListOfMolecules>
      </Species>
      <Species id="S2" concentration="7" name="F">
        <ListOfMolecules>
          <Molecule id="S2_M1" name="F"/>
        </ListOfMolecules>
      </Species>
    </ListOfSpecies>
    <ListOfReactionRules>
      <ReactionRule id="RR1" name="_R1" symmetry_factor="1">
        <ListOfReactantPatterns>
          <ReactantPattern id="RR1_RP1">
            <ListOfMolecules>
              <Molecule id="RR1_RP1_M1" name="X">
                <ListOfComponents>
                  <Component id="RR1_RP1_M1_C1" name="p" state="0" numberOfBonds="0"/>
                </ListOfComponents>
              </Molecule>
            </ListOfMolecules>
          </ReactantPattern>
        </ListOfReactantPatterns>
        <ListOfProductPatterns>
          <ProductPattern id="RR1_PP1">
            <ListOfMolecules>
              <Molecule id="RR1_PP1_M1" name="X">
                <ListOfComponents>
                  <Component id="RR1_PP1_M1_C1" name="p" state="1" numberOfBonds="0"/>
                </ListOfComponents>
              </Molecule>
            </ListOfMolecules>
          </ProductPattern>
        </ListOfProductPatterns>
        <RateLaw id="RR1_RateLaw" type="Ele" totalrate="0">
          <ListOfRateConstants>
            <RateConstant value="kcat"/>
          </ListOfRateConstants>
        </RateLaw>
        <Map>
          <MapItem sourceID="RR1_RP1_M1" targetID="RR1_PP1_M1"/>
          <MapItem sourceID="RR1_RP1_M1_C1" targetID="RR1_PP1_M1_C1"/>
        </Map>
        <ListOfOperations>
          <StateChange site="RR1_RP1_M1_C1" finalState="1"/>
        </ListOfOperations>
      </ReactionRule>
    </ListOfReactionRules>
    <ListOfObservables>
      <Observable id="O1" name="frac" type="Molecules">
        <ListOfPatterns>
          <Pattern id="O1_P1">
            <ListOfMolecules>
              <Molecule id="O1_P1_M1" name="F"/>
            </ListOfMolecules>
          </Pattern>
        </ListOfPatterns>
      </Observable>
    </ListOfObservables>
    <ListOfFunctions>
      <Function id="m_moderate">
        <ListOfReferences>
        </ListOfReferences>
        <Expression> mratio(2.5,1.3,0.7) </Expression>
      </Function>
      <Function id="m_alt">
        <ListOfReferences>
        </ListOfReferences>
        <Expression> mratio(0.5,2.0,3.0) </Expression>
      </Function>
      <Function id="m_negz">
        <ListOfReferences>
        </ListOfReferences>
        <Expression> mratio(4.0,1.5,-1.2) </Expression>
      </Function>
      <Function id="m_bigz">
        <ListOfReferences>
        </ListOfReferences>
        <Expression> mratio(3.2,0.8,5.0) </Expression>
      </Function>
      <Function id="reserved_frac">
        <ListOfReferences>
          <Reference name="frac" type="Observable"/>
        </ListOfReferences>
        <Expression> frac + 10 </Expression>
      </Function>
    </ListOfFunctions>
  </model>
</sbml>
