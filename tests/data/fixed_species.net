# Regression test for Fix #3: SSA honors fixed ($) species
# $A -> B: A is fixed (boundary condition), should never be consumed
begin parameters
    1 k1  0.1  # Constant
end parameters
begin species
    1 $A() 100
    2 B() 0
end species
begin reactions
    1 1 2 k1 #_R1
end reactions
begin groups
    1 A_tot  1
    2 B_tot  2
end groups
