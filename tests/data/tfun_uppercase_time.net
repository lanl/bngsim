# TFUN test: BNG-style canonicalization — uppercase `Time` and trailing `()`
# in the .tfun header (`# Time  cumNcases()`) and an uppercase `Time` index
# argument on the tfun call. Should load identically to tfun_time_indexed.net.
begin parameters
    1 k0  0.0
end parameters
begin functions
    1 cumNcases()  tfun('cumNcases_uppercase.tfun', Time)
end functions
begin species
    1 A() 1
    2 B() 0
end species
begin reactions
    1 1 1,2 cumNcases #R1: A -> A + B at rate cumNcases(t)
end reactions
begin groups
    1 A_tot  1
    2 B_tot  2
end groups
