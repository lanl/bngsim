# Minimal test for ExprTk case-sensitive variable lookup.
# Parameters k3 and K3 differ only by case. They must resolve to
# different values: k3=0.025, K3=15.0.
# Before the fix, ExprTk treated them as the same variable.
# See bngsim/dev/investigations/KHOLODENKO_BUG_REPORT.md.
begin parameters
    1 k3  0.025  # Constant
    2 K3  15.0   # Constant
    3 k4  0.025  # Constant
    4 K4  15.0   # Constant
end parameters
begin functions
    1 rate1() (k3*S1)/(K3+S2)
    2 rate2() (k4*S1)/(K4+S2)
end functions
begin species
    1 S1() 100
    2 S2() 50
    3 P()  0
end species
begin reactions
    1 1 3 rate1 #_R1
    2 2 3 rate2 #_R2
end reactions
begin groups
    1 S1  1
    2 S2  2
    3 P   3
end groups
