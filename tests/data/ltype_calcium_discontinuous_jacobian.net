    1 LTCC(b,g~C,loc~mem,p~U,s~R) LTCC_tot
    2 Calcium() Ca_init
    3 Voltage() 1
    4 LTCC(b,g~O,loc~mem,p~U,s~R) 0
    5 LTCC(b,g~C,loc~mem,p~P,s~R) 0
    6 LTCC(b,g~O,loc~mem,p~P,s~R) 0
    7 LTCC(b,g~O,loc~mem,p~U,s~I) 0
    8 LTCC(b,g~C,loc~mem,p~U,s~I) 0
    9 LTCC(b,g~O,loc~mem,p~P,s~I) 0
   10 LTCC(b,g~C,loc~mem,p~P,s~I) 0
end species
