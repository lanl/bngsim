# GH #176 regression fixture. Generated by BNG2.pl 2.9.3 from rulehub
# Examples/biology/ltypecalciumchanneldynamics/l-type-calcium-channel-dynamics.bngl.
# Its functional rate law v_rec = if((-70+Voltage_Level)<-20, 0.5, 0.05) is
# DISCONTINUOUS in the state Voltage_Level, which asymptotically approaches the
# threshold 50 at t~25. The exact analytical Jacobian omits the jump, so the
# default (analytical) Jacobian de-stabilizes CVODE there (flag=-3) while the
# finite-difference Jacobian (and legacy run_network) integrate cleanly.
# Created by BioNetGen 2.9.3
begin parameters
    1 k_open_max      10.0  # Constant
    2 V_half          -15  # Constant
    3 k_slope         6  # Constant
    4 k_close         0.5  # Constant
    5 k_inact_max     5.0  # Constant
    6 Km_ca           200  # Constant
    7 k_ca_flux       15.0  # Constant
    8 k_ca_pump       0.8  # Constant
    9 k_pka_shift     -5.0  # Constant
   10 k_pka_on        2.0  # Constant
   11 LTCC_tot        500  # Constant
   12 Ca_init         50  # Constant
   13 PKA_stim        0  # Constant
   14 V_Clamp         -30.0  # Constant
   15 k_pka_current   0  # Constant
   16 k_v_stim        50.0  # Constant
   17 k_v_leak        1.0  # Constant
   18 _rateLaw1       20.0  # Constant
   19 _rateLaw2       0.01  # Constant
end parameters
begin functions
    1 v_pka_shift() if((Phospho_LTCC>0),k_pka_shift,0)
    2 v_open() k_open_max/(1+exp(((-((-70+Voltage_Level)-(V_half+v_pka_shift())))/k_slope)))
    3 v_inact() k_inact_max*(Ca_Level/(Km_ca+Ca_Level))
    4 v_rec() if(((-70+Voltage_Level)<-20),0.5,0.05)
end functions
